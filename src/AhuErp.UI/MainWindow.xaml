<Window x:Class="AhuErp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AhuErp.UI.ViewModels"
        xmlns:views="clr-namespace:AhuErp.UI.Views"
        mc:Ignorable="d"
        Title="АХУ ERP/EDMS — МКУ АХУ БМР"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OfficeViewModel}">
            <views:PlaceholderView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ArchiveViewModel}">
            <views:PlaceholderView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ItServiceViewModel}">
            <views:PlaceholderView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FleetViewModel}">
            <views:PlaceholderView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Навигационный сайдбар -->
        <Border Grid.Column="0" Background="{StaticResource Brush.Sidebar.Background}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,24">
                    <TextBlock Text="МКУ АХУ БМР"
                               Foreground="{StaticResource Brush.Sidebar.Foreground}"
                               FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="ERP / EDMS"
                               Foreground="{StaticResource Brush.Sidebar.Accent}"
                               FontSize="12" Margin="0,4,0,0" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource NavButton}"
                                    Content="{Binding Title}"
                                    Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Контентная область -->
        <Border Grid.Column="1" Background="{StaticResource Brush.Content.Background}">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>
