<Window x:Class="AhuErp.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AhuErp.UI.ViewModels"
        Title="Вход в систему — АХУ ERP/EDMS"
        Height="380" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="МКУ АХУ БМР" FontSize="20" FontWeight="Bold" />
        <TextBlock Grid.Row="1" Text="ERP / EDMS"
                   Foreground="{StaticResource Brush.Sidebar.Accent}"
                   FontSize="12" Margin="0,4,0,24" />

        <TextBlock Grid.Row="2" Text="ФИО" Margin="0,0,0,4" />
        <TextBox Grid.Row="3" x:Name="FullNameBox"
                 Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="14" Padding="6" />

        <TextBlock Grid.Row="4" Text="Пароль" Margin="0,12,0,4" />
        <PasswordBox Grid.Row="5" x:Name="PasswordBox"
                     VerticalAlignment="Top"
                     FontSize="14" Padding="6" />

        <StackPanel Grid.Row="6" Margin="0,16,0,0">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#DC2626"
                       Margin="0,0,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
            <Button x:Name="LoginButton"
                    Content="Войти"
                    Height="36" FontSize="14"
                    Command="{Binding LoginCommand}"
                    CommandParameter="{Binding ElementName=PasswordBox, Path=Password}"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
