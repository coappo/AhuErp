<UserControl x:Class="AhuErp.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AhuErp.UI.ViewModels"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             d:DesignHeight="720" d:DesignWidth="1180">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Дашборд руководителя" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{Binding LastRefreshedDisplay}" Margin="16,0,0,0"
                       VerticalAlignment="Center" Foreground="#6B7280" />
            <Button Content="Обновить" Command="{Binding RefreshCommand}"
                    Margin="16,0,0,0" Padding="10,4" />
            <TextBlock Text="Загрузка…" Margin="12,0,0,0" VerticalAlignment="Center"
                       Foreground="#2563EB"
                       Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <Border Grid.Row="1" Background="#FEE2E2" BorderBrush="#DC2626" BorderThickness="1"
                CornerRadius="4" Padding="10,6" Margin="0,0,0,12"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#991B1B" TextWrapping="Wrap" />
        </Border>

        <!-- KPI Cards -->
        <UniformGrid Grid.Row="2" Columns="5" Rows="1" Margin="0,0,0,16">
            <Border Background="White" CornerRadius="4" Padding="16" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Просроченные архив. заявки" Foreground="#6B7280" FontSize="12" />
                    <TextBlock Text="{Binding OverdueArchiveRequests}" FontSize="32" FontWeight="Bold" Foreground="#DC2626" />
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="4" Padding="16" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="ТС в рейсе сейчас" Foreground="#6B7280" FontSize="12" />
                    <TextBlock Text="{Binding ActiveVehicles}" FontSize="32" FontWeight="Bold" Foreground="#2563EB" />
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="4" Padding="16" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="ТМЦ: низкий остаток (&lt; 5)" Foreground="#6B7280" FontSize="12" />
                    <TextBlock Text="{Binding LowStockItems}" FontSize="32" FontWeight="Bold" Foreground="#D97706" />
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="4" Padding="16" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="Просроченные документы (всего)" Foreground="#6B7280" FontSize="12" />
                    <TextBlock Text="{Binding OverdueCount}" FontSize="32" FontWeight="Bold" Foreground="#111827" />
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="4" Padding="16" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Дедлайн ≤ 3 дн." Foreground="#6B7280" FontSize="12" />
                    <TextBlock Text="{Binding DueSoonCount}" FontSize="32" FontWeight="Bold" Foreground="#CA8A04" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Charts -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="4" Padding="16">
                <DockPanel>
                    <TextBlock Text="Документы по статусам" FontWeight="SemiBold" DockPanel.Dock="Top" Margin="0,0,0,8" />
                    <lvc:PieChart Series="{Binding DocumentStatusSeries}"
                                  LegendLocation="Right" InnerRadius="40" Hoverable="True" />
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="4" Padding="16">
                <DockPanel>
                    <TextBlock Text="Остатки ТМЦ по категориям" FontWeight="SemiBold" DockPanel.Dock="Top" Margin="0,0,0,8" />
                    <lvc:CartesianChart Series="{Binding InventoryByCategorySeries}" LegendLocation="Top">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Категория" Labels="{Binding InventoryCategoryLabels}" />
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Единиц" MinValue="0" />
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
