<UserControl x:Class="AhuErp.UI.Views.MyDesktopView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AhuErp.UI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MyDesktopViewModel}"
             d:DesignHeight="700" d:DesignWidth="1200">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">
            <TextBlock Text="{Binding Greeting}" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="  Непрочитано: " Margin="16,0,0,0" VerticalAlignment="Center" />
            <TextBlock Text="{Binding UnreadCount}" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="Отметить всё прочитанным" Command="{Binding MarkAllReadCommand}"
                    Padding="10,4" Margin="16,0,0,0" />
            <Button Content="Обновить" Command="{Binding ReloadCommand}" Padding="10,4" Margin="8,0,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#FFF3CD" BorderBrush="#FFE69C" BorderThickness="1"
                Padding="12,8" CornerRadius="4" Margin="0,12,0,8"
                Visibility="{Binding SubstitutionBanner, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
            <TextBlock Text="{Binding SubstitutionBanner}" Foreground="#664D03" />
        </Border>

        <TabControl Grid.Row="2" Grid.Column="0" Margin="0,8,12,0">
            <TabItem Header="Поручения">
                <DataGrid ItemsSource="{Binding Tasks}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="60" />
                        <DataGridTextColumn Header="Документ" Binding="{Binding Document.Title}" Width="*" />
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*" />
                        <DataGridTextColumn Header="Срок" Binding="{Binding Deadline, StringFormat=dd.MM.yyyy HH:mm}" Width="140" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="На согласовании у меня">
                <TextBlock Margin="12" Foreground="Gray"
                           Text="Список согласований доступен в разделе РКК документа. В Phase 12 здесь появится отдельный API." />
            </TabItem>
            <TabItem Header="Резолюции от меня">
                <TextBlock Margin="12" Foreground="Gray"
                           Text="Список резолюций будет добавлен в Phase 12 вместе с отчётом по исполнительской дисциплине." />
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Grid.Column="1" Background="White" CornerRadius="4" Padding="8" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Уведомления" FontWeight="SemiBold" Margin="4,4,4,8" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Notifications}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                                        Padding="6,8" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Foreground="#333" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Foreground="Gray" FontSize="11" />
                                            <Button Content="Прочитано"
                                                    Command="{Binding DataContext.MarkReadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,2" Margin="12,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
